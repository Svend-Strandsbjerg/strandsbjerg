generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SecurityType {
  STOCK
  INDEX_FUND
  ETF
  OTHER
}

enum TransactionType {
  BUY
  SELL
}

enum AuthMethod {
  CREDENTIALS
  GOOGLE
  MAGIC_LINK
  OAUTH
}

enum CompanyRole {
  COMPANY_ADMIN
  COMPANY_VIEWER
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum CompanyLicenseStatus {
  ACTIVE
  TRIAL
  INACTIVE
  EXPIRED
}

enum CompanyPlanTier {
  FREE
  STANDARD
  ENTERPRISE
}

enum DiscTierAccess {
  FREE
  STANDARD
  DEEP
}

enum AssessmentInviteStatus {
  ACTIVE
  COMPLETED
  INVALIDATED
}

enum DiscAssessmentStatus {
  STARTED
  SUBMITTED
  FAILED
}

enum DiscPromoGrantType {
  FREE_DISC_CREDIT
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           Role           @default(USER)
  approvalStatus ApprovalStatus @default(PENDING)
  discMaxTierOverride DiscTierAccess?

  accounts               Account[]
  sessions               Session[]
  votes                  Vote[]
  createdEvents          FamilyEvent[]           @relation("EventCreator")
  investments            InvestmentEntry[]       @relation("InvestmentCreator")
  securities             Security[]              @relation("SecurityCreator")
  investmentTransactions InvestmentTransaction[] @relation("InvestmentTransactionCreator")
  loginActivities         LoginActivity[]
  discAssessments         DiscAssessment[]
  discPromoLinks          DiscPromoLink[]          @relation("DiscPromoLinkCreator")
  discPromoRedemptions    DiscPromoRedemption[]
  companyMemberships      CompanyMembership[]
  createdAssessmentInvites AssessmentInvite[] @relation("InviteCreator")

  passwordChangedAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Company {
  id        String               @id @default(cuid())
  name      String
  status    CompanyStatus        @default(ACTIVE)
  licenseStatus CompanyLicenseStatus @default(ACTIVE)
  planTier  CompanyPlanTier      @default(FREE)
  seatLimit Int?
  discMaxTierAccess DiscTierAccess @default(FREE)
  selfServiceCreationEnabled Boolean @default(false)
  activatedAt DateTime?
  deactivatedAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  memberships CompanyMembership[]
  invites     AssessmentInvite[]
  promoLinks  DiscPromoLink[]
  assessments DiscAssessment[]
}

model CompanyMembership {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole
  createdAt DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

model AssessmentInvite {
  id              String                 @id @default(cuid())
  token           String                 @unique
  companyId       String
  createdByUserId String
  candidateName   String?
  candidateEmail  String?
  status          AssessmentInviteStatus @default(ACTIVE)
  expiresAt       DateTime
  createdAt       DateTime               @default(now())

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser User             @relation("InviteCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assessments   DiscAssessment[]

  @@index([companyId, status])
  @@index([expiresAt])
}

model DiscAssessment {
  id                  String               @id @default(cuid())
  externalSessionId   String               @unique
  assessmentVersionId String
  userId              String?
  inviteId            String?
  promoRedemptionId   String?
  companyId           String?
  candidateName       String?
  candidateEmail      String?
  createdAt           DateTime             @default(now())
  submittedAt         DateTime?
  status              DiscAssessmentStatus @default(STARTED)
  rawResponses        Json?

  user        User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  resultShare AssessmentResultShare?
  invite  AssessmentInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  promoRedemption DiscPromoRedemption? @relation(fields: [promoRedemptionId], references: [id], onDelete: SetNull)
  company Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([companyId, createdAt])
  @@index([inviteId])
  @@index([promoRedemptionId])
}

model DiscPromoLink {
  id                       String             @id @default(cuid())
  token                    String             @unique
  label                    String
  createdByUserId          String
  companyId                String?
  grantType                DiscPromoGrantType @default(FREE_DISC_CREDIT)
  grantTier                DiscTierAccess     @default(FREE)
  grantCredits             Int                @default(1)
  active                   Boolean            @default(true)
  oneRedemptionPerUser     Boolean            @default(true)
  maxRedemptions           Int?
  expiresAt                DateTime?
  totalRedemptions         Int                @default(0)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  createdByUser User                @relation("DiscPromoLinkCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  company      Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  redemptions  DiscPromoRedemption[]

  @@index([companyId, active])
  @@index([expiresAt])
}

model DiscPromoRedemption {
  id            String   @id @default(cuid())
  promoLinkId   String
  userId        String
  grantedCredits Int     @default(1)
  consumedCredits Int    @default(0)
  redeemedAt    DateTime @default(now())
  lastUsedAt    DateTime?

  promoLink    DiscPromoLink   @relation(fields: [promoLinkId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessments  DiscAssessment[]

  @@index([promoLinkId, userId])
  @@index([userId, redeemedAt])
}


model AssessmentResultShare {
  id           String   @id @default(cuid())
  assessmentId String   @unique
  token        String   @unique
  expiresAt    DateTime?
  firstPdfDownloadedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment DiscAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model FamilyEvent {
  id          String  @id @default(cuid())
  title       String
  description String
  location    String?

  createdById String
  createdBy   User   @relation("EventCreator", fields: [createdById], references: [id], onDelete: Cascade)

  dateOptions EventDateOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventDateOption {
  id            String      @id @default(cuid())
  eventId       String
  event         FamilyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  candidateDate DateTime

  votes Vote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vote {
  id           String @id @default(cuid())
  userId       String
  dateOptionId String

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOption EventDateOption @relation(fields: [dateOptionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, dateOptionId])
}

model HomePageContent {
  singleton String   @id
  headline  String
  intro     String
  sections  String[]
  updatedAt DateTime @updatedAt
}

model ProfessionalPageContent {
  singleton            String   @id
  heroTitle            String
  heroIntro            String
  competencies         String[]
  experienceHighlights String[]
  focusAreas           Json
  updatedAt            DateTime @updatedAt
}

model InvestmentEntry {
  id          String   @id @default(cuid())
  name        String
  amount      Decimal  @db.Decimal(14, 2)
  investedOn  DateTime
  type        String
  createdById String
  createdBy   User     @relation("InvestmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Security {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  isin        String?      @unique
  type        SecurityType
  currency    String
  provider    String?
  source      String?
  createdById String
  createdBy   User         @relation("SecurityCreator", fields: [createdById], references: [id], onDelete: Cascade)

  transactions InvestmentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model InvestmentTransaction {
  id           String          @id @default(cuid())
  securityId   String
  security     Security        @relation(fields: [securityId], references: [id], onDelete: Cascade)
  type         TransactionType @default(BUY)
  transactedOn DateTime
  quantity     Decimal         @db.Decimal(18, 6)
  price        Decimal         @db.Decimal(14, 4)
  fees         Decimal?        @db.Decimal(14, 2)
  notes        String?
  createdById  String
  createdBy    User            @relation("InvestmentTransactionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([securityId])
  @@index([transactedOn])
}

model LoginActivity {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp  DateTime   @default(now())
  authMethod AuthMethod
  ipAddress  String?
  userAgent  String?

  @@index([userId, timestamp])
  @@index([timestamp])
}
