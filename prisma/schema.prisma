generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FAMILY
  USER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SecurityType {
  STOCK
  INDEX_FUND
  ETF
  OTHER
}

enum TransactionType {
  BUY
  SELL
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String?        @unique
  emailVerified  DateTime?
  image          String?
  role           Role           @default(USER)
  approvalStatus ApprovalStatus @default(PENDING)

  accounts               Account[]
  sessions               Session[]
  votes                  Vote[]
  createdEvents          FamilyEvent[]           @relation("EventCreator")
  investments            InvestmentEntry[]       @relation("InvestmentCreator")
  securities             Security[]              @relation("SecurityCreator")
  investmentTransactions InvestmentTransaction[] @relation("InvestmentTransactionCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model FamilyEvent {
  id          String  @id @default(cuid())
  title       String
  description String
  location    String?

  createdById String
  createdBy   User   @relation("EventCreator", fields: [createdById], references: [id], onDelete: Cascade)

  dateOptions EventDateOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventDateOption {
  id            String      @id @default(cuid())
  eventId       String
  event         FamilyEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  candidateDate DateTime

  votes Vote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vote {
  id           String @id @default(cuid())
  userId       String
  dateOptionId String

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOption EventDateOption @relation(fields: [dateOptionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, dateOptionId])
}

model HomePageContent {
  singleton String   @id
  headline  String
  intro     String
  sections  String[]
  updatedAt DateTime @updatedAt
}

model ProfessionalPageContent {
  singleton            String   @id
  heroTitle            String
  heroIntro            String
  competencies         String[]
  experienceHighlights String[]
  focusAreas           Json
  updatedAt            DateTime @updatedAt
}

model InvestmentEntry {
  id          String   @id @default(cuid())
  name        String
  amount      Decimal  @db.Decimal(14, 2)
  investedOn  DateTime
  type        String
  createdById String
  createdBy   User     @relation("InvestmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Security {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  isin        String?      @unique
  type        SecurityType
  currency    String
  provider    String?
  source      String?
  createdById String
  createdBy   User         @relation("SecurityCreator", fields: [createdById], references: [id], onDelete: Cascade)

  transactions InvestmentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model InvestmentTransaction {
  id           String          @id @default(cuid())
  securityId   String
  security     Security        @relation(fields: [securityId], references: [id], onDelete: Cascade)
  type         TransactionType @default(BUY)
  transactedOn DateTime
  quantity     Decimal         @db.Decimal(18, 6)
  price        Decimal         @db.Decimal(14, 4)
  fees         Decimal?        @db.Decimal(14, 2)
  notes        String?
  createdById  String
  createdBy    User            @relation("InvestmentTransactionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([securityId])
  @@index([transactedOn])
}
